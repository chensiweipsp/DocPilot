<UserControl x:Class="DocPilot.Views.Controls.ChatPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.modernwpf.com/2019"
             xmlns:controls="clr-namespace:DocPilot.Views.Controls"
             xmlns:conv="clr-namespace:DocPilot.Converters"
             xmlns:res="clr-namespace:DocPilot.Resources"
             xmlns:vm="clr-namespace:DocPilot.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ChatViewModel}"
             Background="{DynamicResource Palette.Background}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Quick-action bar + export/clear -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <controls:QuickActionsControl Grid.Column="0" DataContext="{Binding}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource GhostButton}"
                        Margin="0,0,4,0"
                        ToolTip="{x:Static res:Strings.ExportAsMarkdown}"
                        Command="{Binding ExportMarkdownCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓" FontSize="14" Margin="0,0,4,0" />
                        <TextBlock Text="MD" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButton}"
                        Margin="0,0,4,0"
                        ToolTip="{x:Static res:Strings.ExportAsText}"
                        Command="{Binding ExportTextCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↓" FontSize="14" Margin="0,0,4,0" />
                        <TextBlock Text="TXT" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding ClearCommand}"
                        Content="{x:Static res:Strings.Clear}" />
            </StackPanel>
        </Grid>

        <!-- Transcript OR empty-state suggestions -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <Grid>
                <!-- Messages -->
                <ScrollViewer x:Name="TranscriptScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="14"
                              Visibility="{Binding HasMessages, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:MessageBubbleControl />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty-state suggestions -->
                <Grid Visibility="{Binding HasMessages, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"
                      Margin="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Grid Margin="0,0,0,12">
                            <Ellipse Width="52" Height="52" Fill="{DynamicResource Accent.AssistantGradient}" Opacity="0.22">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="14" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="💬"
                                       FontSize="32"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource SubtitleText}"
                                   Text="Ask anything about your document" />
                        <TextBlock HorizontalAlignment="Center"
                                   Style="{StaticResource CaptionText}"
                                   Text="Try a quick action above, or pick a suggestion below"
                                   Margin="0,4,0,20" />

                        <!-- Suggestion cards -->
                        <ItemsControl ItemsSource="{Binding SuggestedPrompts}" MaxWidth="440">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PromptCardButton}"
                                            Margin="0,0,0,8"
                                            Command="{Binding DataContext.SuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="✳" Foreground="{DynamicResource Accent.Primary}" Margin="0,0,10,0" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="→" Foreground="{DynamicResource Palette.TextSecondary}" VerticalAlignment="Center" Margin="10,0,0,0" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Composer -->
        <Grid Grid.Row="2" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="InputBox"
                     Style="{StaticResource ChatInputBox}"
                     MinHeight="58"
                     MaxHeight="160"
                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                     ui:ControlHelper.PlaceholderText="{x:Static res:Strings.ChatPlaceholder}"
                     KeyDown="InputBox_OnKeyDown" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,0,0,0">
                <Button Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding StopCommand}"
                        Content="{x:Static res:Strings.Stop}" />
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding SendCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{x:Static res:Strings.Send}" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock Text=" ↵" Foreground="White" Margin="4,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
