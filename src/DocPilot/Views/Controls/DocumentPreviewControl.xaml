<UserControl x:Class="DocPilot.Views.Controls.DocumentPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:DocPilot.Converters"
             xmlns:res="clr-namespace:DocPilot.Resources"
             xmlns:vm="clr-namespace:DocPilot.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DocumentViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource Palette.Background}"
             Foreground="{DynamicResource Palette.TextPrimary}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="📄"
                       FontSize="22"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0" />
            <TextBlock Grid.Column="1"
                       Style="{StaticResource TitleText}"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center"
                       Text="{Binding Document.FileName, TargetNullValue={x:Static res:Strings.OpenDocument}}" />
            <Border Grid.Column="2"
                    CornerRadius="999"
                    Background="{DynamicResource Palette.Hover}"
                    Padding="10,3"
                    VerticalAlignment="Center">
                <TextBlock Style="{StaticResource CaptionText}"
                           Text="{Binding Document.Type}" />
            </Border>
        </Grid>

        <!-- Page content -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="18">
                <TextBox Text="{Binding CurrentPageText, Mode=OneWay}"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{DynamicResource Palette.TextPrimary}"
                         FontFamily="{DynamicResource Font.Mono}"
                         FontSize="13"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Disabled"
                         HorizontalScrollBarVisibility="Disabled" />
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="0,14,0,0"
              Visibility="{Binding HasDocument, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GoPreviousCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="←" Margin="0,0,4,0" />
                    <TextBlock Text="{x:Static res:Strings.Previous}" />
                </StackPanel>
            </Button>

            <Border Grid.Column="1"
                    CornerRadius="999"
                    Background="{DynamicResource Palette.Hover}"
                    Padding="14,4"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" FontWeight="SemiBold">
                    <Run Text="{Binding CurrentPageNumber, Mode=OneWay}" />
                    <Run Text=" / " Foreground="{DynamicResource Palette.TextSecondary}" />
                    <Run Text="{Binding TotalPages, Mode=OneWay}" Foreground="{DynamicResource Palette.TextSecondary}" />
                </TextBlock>
            </Border>

            <Button Grid.Column="2"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding GoNextCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static res:Strings.Next}" />
                    <TextBlock Text="→" Margin="4,0,0,0" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
