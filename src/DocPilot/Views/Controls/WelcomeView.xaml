<UserControl x:Class="DocPilot.Views.Controls.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:DocPilot.Resources"
             xmlns:vm="clr-namespace:DocPilot.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Subtle pulsing animation for the drop-zone glow -->
        <Storyboard x:Key="PulseGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="GlowEffect"
                             Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.75"
                             Duration="0:0:2.2" />
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Ambient radial glow behind the hero -->
        <Ellipse Width="640" Height="640"
                 Opacity="0.12"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center">
            <Ellipse.Fill>
                <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                    <GradientStop Color="#8B5CF6" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="32">

            <!-- Hero badge -->
            <Border HorizontalAlignment="Center"
                    CornerRadius="999"
                    Background="#1A3B82F6"
                    BorderBrush="#553B82F6"
                    BorderThickness="1"
                    Padding="14,6"
                    Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✨" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="Built with Claude"
                               Foreground="{DynamicResource Accent.Primary}"
                               FontSize="{DynamicResource Font.Size.Small}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Hero title with airplane icon -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                <Grid>
                    <Ellipse Width="72" Height="72" Fill="{DynamicResource Accent.HeroGradient}" Opacity="0.25">
                        <Ellipse.Effect>
                            <BlurEffect Radius="20" />
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock Text="✈"
                               FontSize="46"
                               Foreground="{DynamicResource Accent.HeroGradient}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
                <TextBlock Style="{StaticResource HeroText}"
                           Text="DocPilot"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
            </StackPanel>

            <TextBlock HorizontalAlignment="Center"
                       Style="{StaticResource SubtitleText}"
                       Foreground="{DynamicResource Palette.TextSecondary}"
                       Text="Chat with your documents, natively on Windows."
                       Margin="0,0,0,36" />

            <!-- Drop zone card -->
            <Border x:Name="DropCard"
                    Style="{StaticResource Card}"
                    Width="520"
                    Padding="36,30"
                    Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect x:Name="GlowEffect"
                                      BlurRadius="32"
                                      ShadowDepth="0"
                                      Color="#3B82F6"
                                      Opacity="0.35" />
                </Border.Effect>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard Storyboard="{StaticResource PulseGlow}" />
                    </EventTrigger>
                </Border.Triggers>

                <StackPanel HorizontalAlignment="Center">
                    <!-- Dashed drop target -->
                    <Border BorderBrush="{DynamicResource Palette.Border}"
                            BorderThickness="2"
                            CornerRadius="{DynamicResource Corner.Card}"
                            Padding="36,22"
                            Margin="0,0,0,20">
                        <Border.Resources>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                            </Style>
                        </Border.Resources>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="⬇"
                                       FontSize="32"
                                       Foreground="{DynamicResource Accent.Primary}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8" />
                            <TextBlock HorizontalAlignment="Center"
                                       Style="{StaticResource SubtitleText}"
                                       Text="Drop a PDF, DOCX or TXT file here" />
                            <TextBlock HorizontalAlignment="Center"
                                       Style="{StaticResource CaptionText}"
                                       Text="up to 50 MB"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- CTAs -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource PrimaryButton}"
                                Margin="0,0,10,0"
                                Command="{Binding OpenCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="Browse file…" Foreground="White" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding TryDemoCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✨" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="Try sample document" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Feature chips -->
            <ItemsControl HorizontalAlignment="Center" Margin="0,12,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <Border Style="{StaticResource FlatCard}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" Margin="0,0,6,0" />
                        <TextBlock Text="Streaming replies" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource FlatCard}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔐" Margin="0,0,6,0" />
                        <TextBlock Text="DPAPI-encrypted key" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource FlatCard}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌗" Margin="0,0,6,0" />
                        <TextBlock Text="Dark + Light themes" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource FlatCard}" Padding="12,6" Margin="4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📝" Margin="0,0,6,0" />
                        <TextBlock Text="Markdown rendering" Style="{StaticResource CaptionText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </ItemsControl>
        </StackPanel>
    </Grid>
</UserControl>
