<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark palette (default) -->
    <Color x:Key="Palette.BackgroundColor">#0F172A</Color>
    <Color x:Key="Palette.SurfaceColor">#1E293B</Color>
    <Color x:Key="Palette.BorderColor">#334155</Color>
    <Color x:Key="Palette.TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="Palette.TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="Palette.InputBackgroundColor">#0B1220</Color>
    <Color x:Key="Palette.HoverColor">#2A3A52</Color>

    <SolidColorBrush x:Key="Palette.Background"      Color="{StaticResource Palette.BackgroundColor}" />
    <SolidColorBrush x:Key="Palette.Surface"         Color="{StaticResource Palette.SurfaceColor}" />
    <SolidColorBrush x:Key="Palette.Border"          Color="{StaticResource Palette.BorderColor}" />
    <SolidColorBrush x:Key="Palette.TextPrimary"     Color="{StaticResource Palette.TextPrimaryColor}" />
    <SolidColorBrush x:Key="Palette.TextSecondary"   Color="{StaticResource Palette.TextSecondaryColor}" />
    <SolidColorBrush x:Key="Palette.InputBackground" Color="{StaticResource Palette.InputBackgroundColor}" />
    <SolidColorBrush x:Key="Palette.Hover"           Color="{StaticResource Palette.HoverColor}" />
</ResourceDictionary>
